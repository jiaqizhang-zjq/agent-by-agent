# API Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key
ZEN_API_KEY=your_zen_api_key
ZEN_API_BASE=https://api.opencode.com/zen/v1

# Agent Settings
AGENT_NAME=AgentEvolution
AGENT_VERSION=0.1.0

# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///agent_evolution.db

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO

# Third-party services
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key

# Memory settings
MEM0_API_KEY=your_mem0_api_key

# Timeouts
REQUEST_TIMEOUT=30
EXECUTION_TIMEOUT=60

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=2
